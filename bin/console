#!/usr/bin/env ruby
# frozen_string_literal: true

$LOAD_PATH.unshift(File.expand_path("../lib", __dir__))
require "rubyrlm"
require "irb"

api_key = ENV["GEMINI_API_KEY"]
if api_key.to_s.strip.empty?
  warn "GEMINI_API_KEY is missing in environment."
  exit 1
end

model_name = ENV.fetch("RUBYRLM_MODEL", "gemini-3.1-pro-preview")
logger = RubyRLM::Logger::JsonlLogger.new(log_dir: File.expand_path("../logs", __dir__))
client = RubyRLM::Client.new(
  backend: "gemini",
  model_name: model_name,
  api_key: api_key,
  max_depth: 1,
  max_iterations: 20,
  logger: logger,
  verbose: true
)

top = TOPLEVEL_BINDING
main = top.receiver
main.instance_variable_set(:@rubyrlm_client, client)
main.instance_variable_set(:@rubyrlm_logger, logger)
main.instance_variable_set(:@rubyrlm_model_name, model_name)

main.define_singleton_method(:client) { @rubyrlm_client }
main.define_singleton_method(:logger) { @rubyrlm_logger }
main.define_singleton_method(:model_name) { @rubyrlm_model_name }
main.define_singleton_method(:ask) do |client_or_prompt, prompt = nil, root_prompt: nil|
  selected_client = prompt.nil? ? @rubyrlm_client : client_or_prompt
  selected_prompt = prompt.nil? ? client_or_prompt : prompt
  result = selected_client.completion(prompt: selected_prompt, root_prompt: root_prompt)
  puts "\n=> #{result.response}\n"
  result
end

puts <<~TEXT
  RubyRLM interactive console
  - model_name: #{model_name}
  - `client` is preloaded with verbose tracing enabled
  - use: ask(client, "Your question") or ask("Your question")
  - logs written to: #{File.expand_path("../logs", __dir__)}
TEXT

IRB.start
